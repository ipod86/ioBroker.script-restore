	"title": "Script Restore",
	"description": "Restore ioBroker scripts from backup archives",
	"authorName": "ipod86",
	"authorEmail": "david@graef.email",
	"authorGithub": "ipod86",
	"language": "TypeScript",
	"features": ["adapter"],
	"adminUi": "html",
	"adminFeatures": ["tab"],
	"tools": ["ESLint", "Prettier"],
