{
    "type": "tabs",
    "i18n": true,
    "items": {
        "tabLocal": {
            "type": "panel",
            "label": "localSection",
            "items": {
                "localEnabled": {
                    "type": "checkbox",
                    "label": "localEnabled",
                    "default": true,
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12
                },
                "_divLocal": {
                    "type": "divider"
                },
                "backupPath": {
                    "type": "text",
                    "label": "backupPath",
                    "placeholder": "/opt/iobroker/backups",
                    "hidden": "!data.localEnabled",
                    "xs": 12,
                    "sm": 9,
                    "md": 9,
                    "lg": 10,
                    "xl": 10
                },
                "_suggestBtn": {
                    "type": "sendTo",
                    "command": "suggestBackupPath",
                    "label": "suggestPath",
                    "hidden": "!data.localEnabled",
                    "xs": 12,
                    "sm": 3,
                    "md": 3,
                    "lg": 2,
                    "xl": 2
                }
            }
        },
        "tabFtp": {
            "type": "panel",
            "label": "ftpSection",
            "items": {
                "ftpEnabled": {
                    "type": "checkbox",
                    "label": "ftpEnabled",
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12
                },
                "_divFtp": {
                    "type": "divider"
                },
                "ftpHost": {
                    "type": "text",
                    "label": "ftpHost",
                    "placeholder": "192.168.1.100",
                    "hidden": "!data.ftpEnabled",
                    "xs": 12,
                    "sm": 6,
                    "md": 6,
                    "lg": 6,
                    "xl": 6
                },
                "ftpPort": {
                    "type": "number",
                    "label": "ftpPort",
                    "placeholder": "21",
                    "min": 1,
                    "max": 65535,
                    "hidden": "!data.ftpEnabled",
                    "xs": 12,
                    "sm": 3,
                    "md": 3,
                    "lg": 3,
                    "xl": 3
                },
                "ftpSecure": {
                    "type": "checkbox",
                    "label": "ftpSecure",
                    "hidden": "!data.ftpEnabled",
                    "xs": 12,
                    "sm": 3,
                    "md": 3,
                    "lg": 3,
                    "xl": 3
                },
                "ftpUser": {
                    "type": "text",
                    "label": "ftpUser",
                    "placeholder": "anonymous",
                    "hidden": "!data.ftpEnabled",
                    "xs": 12,
                    "sm": 6,
                    "md": 6,
                    "lg": 6,
                    "xl": 6
                },
                "ftpPassword": {
                    "type": "password",
                    "label": "ftpPassword",
                    "hidden": "!data.ftpEnabled",
                    "xs": 12,
                    "sm": 6,
                    "md": 6,
                    "lg": 6,
                    "xl": 6
                },
                "ftpPath": {
                    "type": "text",
                    "label": "ftpPath",
                    "placeholder": "/backups",
                    "hidden": "!data.ftpEnabled",
                    "xs": 12,
                    "sm": 9,
                    "md": 9,
                    "lg": 9,
                    "xl": 9
                },
                "_ftpTestBtn": {
                    "type": "sendTo",
                    "command": "testFtp",
                    "label": "testConnection",
                    "hidden": "!data.ftpEnabled",
                    "xs": 12,
                    "sm": 3,
                    "md": 3,
                    "lg": 3,
                    "xl": 3
                }
            }
        },
