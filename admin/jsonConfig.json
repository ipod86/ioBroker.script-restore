{
    "type": "tabs",
    "items": {
        "tabLocal": {
            "type": "panel",
            "label": {"en": "Local Backups", "de": "Lokale Backups"},
            "items": {
                "localEnabled": {
                    "type": "checkbox",
                    "label": {"en": "Enable local backups", "de": "Lokale Backups aktivieren"},
                    "default": true
                },
                "_divLocal": {"type": "divider"},
                "backupPath": {
                    "type": "text",
                    "label": {"en": "Backup path", "de": "Backup-Pfad"},
                    "placeholder": "/opt/iobroker/backups",
                    "sm": 10,
                    "hidden": "!data.localEnabled"
                },
                "_suggestBtn": {
                    "type": "sendTo",
                    "command": "suggestBackupPath",
                    "label": {"en": "Suggest path", "de": "Pfad vorschlagen"},
                    "copyToField": "backupPath",
                    "sm": 2,
                    "hidden": "!data.localEnabled"
                }
            }
        },
        "tabFtp": {
            "type": "panel",
            "label": "FTP",
            "items": {
                "ftpEnabled": {
                    "type": "checkbox",
                    "label": {"en": "Enable FTP", "de": "FTP aktivieren"}
                },
                "_divFtp": {"type": "divider"},
                "ftpHost": {
                    "type": "text",
                    "label": {"en": "Host", "de": "Host"},
                    "placeholder": "192.168.1.100",
                    "hidden": "!data.ftpEnabled"
                },
                "ftpPort": {
                    "type": "number",
                    "label": {"en": "Port", "de": "Port"},
                    "placeholder": "21",
                    "min": 1,
                    "max": 65535,
                    "hidden": "!data.ftpEnabled"
                },
                "ftpSecure": {
                    "type": "checkbox",
                    "label": {"en": "Use FTPS (TLS)", "de": "FTPS (TLS) verwenden"},
                    "hidden": "!data.ftpEnabled"
                },
                "ftpUser": {
                    "type": "text",
                    "label": {"en": "User", "de": "Benutzer"},
                    "placeholder": "anonymous",
                    "hidden": "!data.ftpEnabled"
                },
                "ftpPassword": {
                    "type": "password",
                    "label": {"en": "Password", "de": "Passwort"},
                    "hidden": "!data.ftpEnabled"
                },
                "ftpPath": {
                    "type": "text",
                    "label": {"en": "Path", "de": "Pfad"},
                    "placeholder": "/backups",
                    "hidden": "!data.ftpEnabled"
                },
                "_ftpTestBtn": {
                    "type": "sendTo",
                    "command": "testFtp",
                    "label": {"en": "Test connection", "de": "Verbindung testen"},
                    "hidden": "!data.ftpEnabled"
                }
            }
        },
        "tabSmb": {
            "type": "panel",
            "label": {"en": "SMB (v2)", "de": "SMB (v2)"},
            "items": {
                "smbEnabled": {
                    "type": "checkbox",
                    "label": {"en": "Enable SMB", "de": "SMB aktivieren"}
                },
                "_smbInfo": {
                    "type": "staticText",
                    "text": {"en": "Only SMB2 is supported.", "de": "Es wird nur SMB2 unterstützt."},
                    "hidden": "!data.smbEnabled"
                },
                "_divSmb": {"type": "divider"},
                "smbHost": {
                    "type": "text",
                    "label": {"en": "Host / IP", "de": "Host / IP"},
                    "placeholder": "192.168.1.100",
                    "hidden": "!data.smbEnabled"
                },
                "smbShare": {
                    "type": "text",
                    "label": {"en": "Share name", "de": "Freigabename"},
                    "placeholder": "Backups",
                    "hidden": "!data.smbEnabled"
                },
                "smbPath": {
                    "type": "text",
                    "label": {"en": "Sub-path (optional)", "de": "Unterordner (optional)"},
                    "hidden": "!data.smbEnabled"
                },
                "smbDomain": {
                    "type": "text",
                    "label": {"en": "Domain (optional)", "de": "Domain (optional)"},
                    "hidden": "!data.smbEnabled"
                },
                "smbUser": {
                    "type": "text",
                    "label": {"en": "User", "de": "Benutzer"},
                    "hidden": "!data.smbEnabled"
                },
                "smbPassword": {
                    "type": "password",
                    "label": {"en": "Password", "de": "Passwort"},
                    "hidden": "!data.smbEnabled"
                },
                "_smbTestBtn": {
                    "type": "sendTo",
                    "command": "testSmb",
                    "label": {"en": "Test connection", "de": "Verbindung testen"},
                    "hidden": "!data.smbEnabled"
                }
            }
        },
        "tabHttp": {
            "type": "panel",
            "label": "HTTP/HTTPS",
            "items": {
                "httpEnabled": {
                    "type": "checkbox",
                    "label": {"en": "Enable HTTP/HTTPS source", "de": "HTTP/HTTPS-Quelle aktivieren"}
                },
                "_httpInfo": {
                    "type": "staticText",
                    "text": {"en": "Enter a direct URL to a .tar.gz backup file in the main tab. The protocol (https://) is added automatically if omitted.", "de": "Im Haupt-Tab eine direkte URL zu einer .tar.gz-Backup-Datei eingeben. Das Protokoll (https://) wird automatisch ergänzt, falls weggelassen."},
                    "hidden": "!data.httpEnabled"
                }
            }
        },
        "tabSftp": {
            "type": "panel",
            "label": "SFTP",
            "items": {
                "sftpEnabled": {
                    "type": "checkbox",
                    "label": {"en": "Enable SFTP", "de": "SFTP aktivieren"}
                },
                "_divSftp": {"type": "divider"},
                "sftpHost": {
                    "type": "text",
                    "label": {"en": "Host / IP", "de": "Host / IP"},
                    "placeholder": "192.168.1.100",
                    "hidden": "!data.sftpEnabled"
                },
                "sftpPort": {
                    "type": "number",
                    "label": {"en": "Port", "de": "Port"},
                    "placeholder": "22",
                    "min": 1,
                    "max": 65535,
                    "hidden": "!data.sftpEnabled"
                },
                "sftpUser": {
                    "type": "text",
                    "label": {"en": "User", "de": "Benutzer"},
                    "hidden": "!data.sftpEnabled"
                },
                "sftpPassword": {
                    "type": "password",
                    "label": {"en": "Password", "de": "Passwort"},
                    "hidden": "!data.sftpEnabled"
                },
                "sftpPath": {
                    "type": "text",
                    "label": {"en": "Path", "de": "Pfad"},
                    "placeholder": "/",
                    "hidden": "!data.sftpEnabled"
                },
                "_sftpTestBtn": {
                    "type": "sendTo",
                    "command": "testSftp",
                    "label": {"en": "Test connection", "de": "Verbindung testen"},
                    "hidden": "!data.sftpEnabled"
                }
            }
        },
        "tabWebdav": {
            "type": "panel",
            "label": "WebDAV",
            "items": {
                "webdavEnabled": {
                    "type": "checkbox",
                    "label": {"en": "Enable WebDAV", "de": "WebDAV aktivieren"}
                },
                "_divWebdav": {"type": "divider"},
                "webdavUrl": {
                    "type": "text",
                    "label": {"en": "Server URL", "de": "Server-URL"},
                    "placeholder": "https://cloud.example.com/remote.php/webdav",
                    "hidden": "!data.webdavEnabled"
                },
                "webdavUser": {
                    "type": "text",
                    "label": {"en": "User", "de": "Benutzer"},
                    "hidden": "!data.webdavEnabled"
                },
                "webdavPassword": {
                    "type": "password",
                    "label": {"en": "Password", "de": "Passwort"},
                    "hidden": "!data.webdavEnabled"
                },
                "webdavPath": {
                    "type": "text",
                    "label": {"en": "Path", "de": "Pfad"},
                    "placeholder": "/",
                    "hidden": "!data.webdavEnabled"
                },
                "_webdavTestBtn": {
                    "type": "sendTo",
                    "command": "testWebdav",
                    "label": {"en": "Test connection", "de": "Verbindung testen"},
                    "hidden": "!data.webdavEnabled"
                }
            }
        }
    }
}
